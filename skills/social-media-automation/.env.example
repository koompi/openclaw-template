# Facebook
FB_PAGE_ACCESS_TOKEN=your_page_token_here
FB_PAGE_ID=your_page_id_here

# Instagram (via Meta)
# IG_ACCESS_TOKEN=
# IG_BUSINESS_ACCOUNT_ID=

# Threads
# THREADS_ACCESS_TOKEN=
# THREADS_USER_ID=

# TikTok (Experimental - cookie file in mcp-servers/tiktok-uploader/TK_cookies_<username>.json)
# TIKTOK_TEST_USERNAME=

# X/Twitter
# X_ACCESS_TOKEN=
# X_CLIENT_ID=
# X_CLIENT_SECRET=

# YouTube
# YOUTUBE_ACCESS_TOKEN=
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=

# LinkedIn
# LINKEDIN_ACCESS_TOKEN=
# LINKEDIN_PERSON_ID=

# Pinterest
# PINTEREST_ACCESS_TOKEN=
# PINTEREST_ADVERTISER_ID=

# Bluesky
# BLUESKY_HANDLE=
# BLUESKY_APP_PASSWORD=

# Mastodon
# MASTODON_INSTANCE_URL=https://mastodon.social
# MASTODON_ACCESS_TOKEN=

# GitHub (for pushing updates)
# GH_TOKEN=
